# ============================================
# CAMERA RENTAL - PRODUCTION CONFIG
# ============================================
# Copy file này thành .env và cập nhật các giá trị

PORT=5000
NODE_ENV=production

# ============================================
# MONGODB - NÊN TẠO DATABASE MỚI CHO PRODUCTION
# ============================================
# Option 1: Dùng chung cluster (khuyến nghị tạo database riêng)
MONGODB_URI=mongodb+srv://admin:YOUR_PASSWORD@your-cluster.mongodb.net/camera_rental_production?appName=cameraRental

# ============================================
# JWT - BẮT BUỘC ĐỔI SECRET MỚI!
# ============================================
# Tạo secret mới: openssl rand -base64 64
JWT_SECRET=YOUR_NEW_RANDOM_64_CHARACTER_SECRET_HERE
JWT_EXPIRES_IN=7d

# ============================================
# FRONTEND URL - CẬP NHẬT SAU KHI DEPLOY
# ============================================
CLIENT_URL=https://your-frontend-domain.com

# ============================================
# GOOGLE OAUTH - CẬP NHẬT TRONG GOOGLE CLOUD CONSOLE
# ============================================
# 1. Vào Google Cloud Console → APIs & Services → Credentials
# 2. Chọn OAuth 2.0 Client ID
# 3. Thêm Authorized redirect URIs:
#    - https://your-domain.com/api/auth/google/callback
# 4. Copy Client ID và Secret mới vào đây
GOOGLE_CLIENT_ID=your-production-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-production-client-secret
GOOGLE_CALLBACK_URL=https://your-domain.com/api/auth/google/callback

# ============================================
# EMAIL
# ============================================
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
# App Password (không phải password thường)
# Tạo: Google Account → Security → 2-Step Verification → App Passwords
EMAIL_PASS=xxxx xxxx xxxx xxxx

# ============================================
# TELEGRAM BOT
# ============================================
# Bot Token từ @BotFather (giữ nguyên nếu dùng bot hiện tại)
TELEGRAM_BOT_TOKEN=your-bot-token
# Chat ID của bạn (gửi message cho @userinfobot để lấy)
TELEGRAM_CHAT_ID=your-chat-id

# ============================================
# VIETQR - PRODUCTION CREDENTIALS
# ============================================
# Đăng ký tài khoản VietQR Production tại:
# https://vietqr.net
VIETQR_CLIENT_ID=your-production-client-id
VIETQR_API_KEY=your-production-api-key
VIETQR_ACCOUNT_NUMBER=your-bank_account_number
VIETQR_ACCOUNT_NAME=YOUR NAME
VIETQR_BANK_CODE=970416
VIETQR_BANK_NAME=ACB

# ============================================
# VNPAY - PRODUCTION CREDENTIALS
# ============================================
# Đăng ký tài khoản VNPAY Merchant tại:
# https://merchant.vnpayment.vn
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=https://your-domain.com/api/payment/vnpay/return
VNPAY_IPN_URL=https://your-domain.com/api/payment/vnpay/ipn
VNPAY_TMN_CODE=your-tmn-code
VNPAY_HASH_SECRET=your-hash-secret

# ============================================
# AWS S3 - Production Bucket
# ============================================
# Khuyến nghị: Tạo bucket riêng cho production
AWS_REGION=ap-southeast-2
AWS_BUCKET_NAME=your-production-bucket
AWS_ACCESS_KEY=AKIAXXXXXXXXXXXXXXXXXX
AWS_SECRET_KEY=your-production-secret-key

# ============================================
# GEMINI AI
# ============================================
# API Key từ Google AI Studio:
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
